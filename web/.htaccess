# Flutter Web Apache Configuration for cPanel
# MIME types for CanvasKit/WASM
AddType application/wasm .wasm
AddType text/plain .symbols

# Cache static assets (1 year)
<FilesMatch "\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|wasm|symbols)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# No cache for HTML, service worker, and manifest
<FilesMatch "\.(html|json|js)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
</FilesMatch>

# Disable directory listing
Options -Indexes

# Default charset
AddDefaultCharset UTF-8